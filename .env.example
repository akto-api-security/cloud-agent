# Client change for proxy = one line (sign-then-relay).
# Full guide: docs/CLIENT-INTEGRATION.md
#
# BEDROCK_ENDPOINT_URL=https://akto-proxy?openai_url=https://bedrock-runtime.<region>.amazonaws.com
# SDK signs for bedrock-runtime host; openai_url is proxy routing only (unsigned on forward).

AWS_PROFILE=cloud-agent-bedrock
AWS_REGION=us-east-1

# Do NOT set AWS_BEARER_TOKEN_BEDROCK when using SigV4

BEDROCK_MODEL_ID=amazon.nova-micro-v1:0
BEDROCK_MAX_TOKENS=256

PORT=8000
