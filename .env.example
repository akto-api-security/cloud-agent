# Client change for proxy = one line (sign-then-relay).
# Full guide: docs/CLIENT-INTEGRATION.md
#
# Copy to .env and fill in your values:
#   cp .env.example .env

AWS_PROFILE=cloud-agent-bedrock
AWS_REGION=ap-south-1

# Do NOT set AWS_BEARER_TOKEN_BEDROCK when using SigV4

BEDROCK_MODEL_ID=apac.amazon.nova-micro-v1:0
BEDROCK_MAX_TOKENS=256
PORT=8000

# --- Akto proxy (uncomment for proxy mode) ---
# BEDROCK_ENDPOINT_URL=https://akto-proxy?openai_url=https://bedrock-runtime.ap-south-1.amazonaws.com

# --- Streaming (ConverseStream, boto3 CRC32-validated event stream) ---
# Forces ConverseStream even with tools. Old proxy may raise ChecksumMismatch.
# BEDROCK_STREAM=true
